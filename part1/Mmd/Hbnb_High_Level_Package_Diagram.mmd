%%{init: {'theme': 'dark', 'themeVariables': { 'lineColor': '#ffffff', 'clusterBkg': 'transparent', 'clusterBorder': '#ffffff', 'mainBkg': 'transparent', 'nodeBorder': '#ffffff'}}}%%
flowchart TD
    %% Base styling to ensure transparent boxes and white text
    classDef default fill:transparent,stroke:#ffffff,stroke-width:1px,color:#ffffff

    %% Actor (Using fa-male for a more "stick-figure" human appearance)
    User(("fa:fa-male<br>User"))

    %% Main System Boundary
    subgraph System ["HBnB System"]
        
        %% Presentation Layer
        subgraph PL ["Presentation Layer"]
            Services["Services"] ~~~ API["API"]
        end

        %% Business Logic Layer
        subgraph BLL ["BusinessLogicLayer"]
            Facade["Facade"]
            
            subgraph Model ["Model Package"]
                %% Grid layout for Model items to match the cross-like shape
                UserM["User"] ~~~ Place["Place"]
                Favorite["Favorite"]
                Amenity["Amenity"] ~~~ Review["Review"]
                
                %% Invisible links to force Favorite to the middle
                UserM ~~~ Favorite
                Place ~~~ Favorite
                Favorite ~~~ Amenity
                Favorite ~~~ Review
            end
            
            %% Connection from Facade to the Model Package boundary
            Facade --> Model
        end

        %% Persistence Layer
        subgraph PerL ["PersistenceLayer"]
            %% Grid structure
            RevR["Review Repo"] ~~~ PlaceR["Place Repo"]
            AmenR["Amenity Repo"] ~~~ UserR["User Repo"]
            
            %% Vertical alignment enforcement
            RevR ~~~ AmenR
            PlaceR ~~~ UserR
        end
        
        %% Layer-to-Layer Connections with dark background labels for readability
        PL -->|"<span style='background-color:#333333; padding:2px 6px; border-radius:4px;'>Facade Pattren</span>"| BLL
        BLL -->|"<span style='background-color:#333333; padding:2px 6px; border-radius:4px;'>Database Operations</span>"| PerL
    end

    %% Actor Connection to the System
    User -.-> PL